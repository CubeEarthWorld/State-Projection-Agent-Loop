# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# DeepSeek API key for live integration tests (tests/integration/)
DEEPSEEK_API_KEY=
# Model name to use for live tests
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional: local path to an embeddinggemma-300m GGUF file.
# If unset, integration tests download it from Hugging Face into the HF cache.
SPAL_EMBED_GGUF=

# Set to 1 to enable live integration tests (they cost API credits)
SPAL_RUN_LIVE=
